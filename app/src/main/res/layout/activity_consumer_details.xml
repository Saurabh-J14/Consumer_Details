<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.ConsumerDetailsActivity">


    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/headerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue_dark"
        android:fitsSystemWindows="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!--        <ImageButton-->
        <!--            android:id="@+id/imgClose"-->
        <!--            android:layout_width="match_parent"-->
        <!--            android:layout_height="wrap_content"-->
        <!--            android:layout_weight="1.80"-->
        <!--            android:backgroundTint="@android:color/transparent"-->
        <!--            android:src="@drawable/ic_back"-->
        <!--            app:tint="@color/white" />-->

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            android:background="@color/blue_dark"
            app:title="Consumer Details"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_back"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"/>

    </com.google.android.material.appbar.AppBarLayout>
    <!-- Shimmer Layout -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_view_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerView">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/data_consumer_placeholder" />

            <!--            <include layout="@layout/data_placeholder_layout" />-->

            <!--            <include layout="@layout/data_placeholder_layout" />-->

            <!--            <include layout="@layout/data_placeholder_layout" />-->

            <!--            <include layout="@layout/data_placeholder_layout" />-->

            <!--            <include layout="@layout/data_placeholder_layout" />-->
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>


    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnupdateConsumer"
        app:layout_constraintTop_toBottomOf="@id/headerView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/headerView"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:layout_marginVertical="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CurrentLocation"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/consumerlocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="15dp"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:cursorVisible="false"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:hint="Location"
                        android:inputType="none"
                        android:longClickable="true"
                        android:padding="7dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textIsSelectable="false"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:singleLine="true"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Consumer Number"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/etconsumerno"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:hint="Consumer Number"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Meter Number"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/etMeter_no"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:padding="5dp"
                        android:textSize="11sp"
                        android:hint="Meter Number"
                        android:textColor="@color/black"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Voltage"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/etvoltage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:hint="Voltage"
                        android:padding="5dp"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Circle"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/etcircle_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:hint="Circle"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DTC Name"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/etdtc_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:hint="DTC Name"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SanctionedLoad"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <EditText
                        android:id="@+id/etsanctionedload"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:hint="SanctionedLoad"
                        android:padding="5dp"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ConsumerStatus"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/etconsumerNumber"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:hint="ConsumerStatus"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Division Name"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/txtDivision"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:padding="5dp"
                        android:hint="Division Name"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Create On"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/txt_Created"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:padding="5dp"
                        android:hint="Created On"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SubstationName"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/txt_Substation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:padding="5dp"
                        android:hint="SubstationName"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FeederName"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/txt_Feedername"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:hint="FeederName"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mobile No"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/txt_Mobileno"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:padding="5dp"
                        android:hint="Mobile No"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Feeder ID"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/etfeedr"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:background="@drawable/tv_background"
                        android:hint="Feeder ID"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/phaselayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phase"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="11sp"/>

                    <EditText
                        android:id="@+id/etphases"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:background="@drawable/tv_background"
                        android:hint="Phase"
                        android:textSize="11sp"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:layout_marginEnd="5dp"
                        android:layout_marginStart="50dp"/>

                    <Button
                        android:id="@+id/btnPhase"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:layout_weight="1"
                        android:text="Check"
                        android:visibility="gone"
                        android:textAllCaps="false"
                        android:textSize="11sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="4dp">

                    <Button
                        android:id="@+id/btnPhases"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Connect to Decive"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:textColor="@color/white"/>

                </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBleTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:text="Bluetooth (BLE)"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/black" />

                        <Button
                            android:id="@+id/btnBluetooth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:text="Scan BLE Devices"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textAllCaps="false" />

                        <TextView
                            android:id="@+id/tvBleStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="2dp"
                            android:text="Status: Idle"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/black" />

                        <ListView
                            android:id="@+id/listDevices"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:layout_marginTop="8dp"
                            android:scrollbars="vertical"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tvBleCharTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="10dp"
                            android:text="Characteristics"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvBleCharStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="2dp"
                            android:text="Status: Idle"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/black" />

                        <ListView
                            android:id="@+id/listCharacteristics"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:layout_marginTop="6dp"
                            android:scrollbars="vertical"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tvBleDataLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="10dp"
                            android:text="Received Data"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvBleData"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/tv_background"
                            android:padding="8dp"
                            android:text="No data"
                            android:textSize="12sp"
                            android:textColor="@color/black" />

                    </LinearLayout>

                <LinearLayout
                    android:id="@+id/recevie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sharing with you"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#5A4A4A"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="40dp"/>

                    <LinearLayout
                        android:id="@+id/centerCard"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_below="@id/tvTitle"
                        android:layout_margin="24dp"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <ImageView
                            android:id="@+id/images"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/receive"
                            android:layout_marginBottom="15dp"/>

                        <TextView
                            android:id="@+id/tvStatuss"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ready to receive"
                            android:textSize="20sp"
                            android:textColor="#5A4A4A"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etMessage"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginStart="24dp"
                        android:layout_marginEnd="24dp"
                        android:layout_marginTop="10dp"
                        android:hint="Enter message"
                        android:padding="10dp"/>

                    <LinearLayout
                        android:id="@+id/bottomBar"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_alignParentBottom="true"
                        android:background="#E5CACA"
                        android:gravity="center"
                        android:visibility="gone"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/btnReceive"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:src="@android:drawable/stat_sys_download_done"                                    />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Receive"
                                android:textSize="16sp"
                                android:textColor="#4A2C2C"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/btnSend"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:src="@android:drawable/stat_sys_upload_done" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Send"
                                android:textSize="16sp"
                                android:textColor="#4A2C2C"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="25dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.example.feeder.custom.Donut3DChartView
                        android:id="@+id/donutChart"
                        android:layout_width="250dp"
                        android:layout_height="250dp"
                        android:layout_gravity="center"/>

                    <TextView
                        android:id="@+id/total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Confrom Phase"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>-->

                <LinearLayout
                    android:id="@+id/layoutSpeedometer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <com.example.feeder.custom.PhasorView
                        android:id="@+id/phasorView"
                        android:layout_width="250dp"
                        android:layout_height="250dp"/>

                    <TextView
                        android:id="@+id/tvSpeedLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Confirm Phase"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/txtOpenCamera"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/circle_bg"
                        android:src="@drawable/photo_camera"
                        android:padding="15dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/updatePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Upload Photo"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:visibility="gone"/>

                    <ImageView
                        android:id="@+id/imgPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginHorizontal="12dp"
                        android:scaleType="fitXY"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>

        </ScrollView>


    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <Button
        android:id="@+id/btnupdateConsumer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="45dp"
        android:gravity="center"
        android:nestedScrollingEnabled="false"
        android:text="Save"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
